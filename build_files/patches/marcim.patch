+			case 1: /* 2.4 GHz */
+				band_idx = 0;
+				break;
+			case 2: /* 5 GHz */
+			case 3: /* 6 GHz */
+				band_idx = 1;
+				break;
+			default:
+				/* keep the previously stable band assignment */
